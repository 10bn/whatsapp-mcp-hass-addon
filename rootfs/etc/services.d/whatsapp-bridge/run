#!/usr/bin/with-contenv bashio
# ==============================================================================
# Start the Go WhatsApp bridge (whatsmeow client + local REST API).
# Session credentials and the message history SQLite databases are kept on
# the persistent /data volume so re-pairing isn't needed after a restart.
# s6-overlay docs: https://github.com/just-containers/s6-overlay
# ==============================================================================

mkdir -p /data/store

source /etc/whatsapp-mcp/secret.sh
declare shared_secret
shared_secret="$(resolve_or_generate_shared_secret)"

export WHATSAPP_STORE_DIR="/data/store"
export WHATSAPP_PORT="8080"
export WHATSAPP_QR_PORT="8082"
# Reuse the app's single shared secret to gate the pairing QR image too,
# rather than introducing a second token users have to manage.
export WHATSAPP_QR_TOKEN="${shared_secret}"

cd /app/whatsapp-bridge || bashio::exit.nok "Could not change to /app/whatsapp-bridge"

# Reflects any host port remapped on this app's Network tab, so the URLs
# logged below are actually reachable rather than showing the internal port.
declare qr_public_port
qr_public_port="$(bashio::addon.port 8082)"
if ! bashio::var.has_value "${qr_public_port}"; then
    qr_public_port=8082
fi

bashio::log.info "Starting WhatsApp bridge..."
bashio::log.info "If this is the first run, a QR code will appear below - scan it with the WhatsApp app on your phone (Settings > Linked Devices)."
if [ -n "${shared_secret}" ]; then
    bashio::log.info "If the QR code doesn't render properly in this log viewer: in a browser, go to the SAME address/IP you use for Home Assistant itself, but with port ${qr_public_port} instead, then open path /qr.png?token=${shared_secret} - e.g. http://192.168.1.50:${qr_public_port}/qr.png?token=${shared_secret}. This only works while pairing is in progress."
else
    bashio::log.warning "disable_auth is set, so the QR image endpoint on port ${qr_public_port} is unauthenticated while pairing - anyone on your network could load it during that window."
    bashio::log.info "If the QR code doesn't render properly in this log viewer: in a browser, go to the SAME address/IP you use for Home Assistant itself, but with port ${qr_public_port} instead, then open path /qr.png - e.g. http://192.168.1.50:${qr_public_port}/qr.png. This only works while pairing is in progress."
fi

exec ./whatsapp-bridge
